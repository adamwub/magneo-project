# apps/api — contoh konfigurasi. SALIN ke .env (jangan commit .env). Lihat BAGIAN 16 aplikasi.md.

# Wajib:
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://magnoo:magnoo@localhost:5432/magnoo

# Wajib sejak Fase 1b (auth) — min 32 karakter. Buat acak, mis: openssl rand -base64 48
JWT_ACCESS_SECRET=dev-only-access-secret-change-me-32chars-min
JWT_REFRESH_SECRET=dev-only-refresh-secret-change-me-32chars-min
# Opsional (punya default): JWT_ACCESS_TTL_SEC=3600  JWT_REFRESH_TTL_SEC=2592000

# Disiapkan untuk fase berikut:
# REDIS_URL=redis://localhost:6379
# ANTHROPIC_API_KEY=              # via module ai saja (ADR-007)
# OBJECT_STORAGE_ENDPOINT=
# BOX_PAIRING_PEPPER=
# AI_MONTHLY_COST_CAP_DEFAULT_IDR=3000000
